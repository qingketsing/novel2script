# Local runtime mode.
# Use "mock" for stable demos without external network access.
# Use "deepseek" only when DEEPSEEK_API_KEY is configured locally.
AI_MODE=mock

# Keep demo stable if DeepSeek mode fails or the API key is missing.
AI_FALLBACK_TO_MOCK=true

# Backend listen address. Docker images should keep this as :8080.
HTTP_ADDR=:8080

# DeepSeek-compatible API settings.
# Never put a real API key in this example file.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30

# Reserved for docker compose port mapping.
BACKEND_PORT=8080
FRONTEND_PORT=5173
