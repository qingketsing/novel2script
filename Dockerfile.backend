FROM golang:1.25 AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY backend ./backend
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/novel2script-server ./backend/cmd/server

FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /app

COPY --from=builder /out/novel2script-server /app/novel2script-server

ENV HTTP_ADDR=:8080
ENV AI_MODE=mock
ENV AI_FALLBACK_TO_MOCK=true

EXPOSE 8080

ENTRYPOINT ["/app/novel2script-server"]
